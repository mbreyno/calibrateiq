# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase service role key — server-side only, never expose to browser
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Used for the questionnaire link base URL (update for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email notifications — Resend (https://resend.com)
# Get your API key from the Resend dashboard (free tier: 3,000 emails/month)
RESEND_API_KEY=re_YOUR_API_KEY

# The "from" address for advisor notification emails.
# On Resend's free plan (no verified domain), use: onboarding@resend.dev
# For a branded address, verify your domain in the Resend dashboard first.
NOTIFY_FROM_EMAIL=onboarding@resend.dev

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# The recurring price ID for the $9/month plan
# Create in: Stripe dashboard → Products → Add product → $9/month recurring
STRIPE_PRICE_ID=price_...

# Webhook signing secret — get from: Stripe dashboard → Webhooks → your endpoint → Signing secret
# Events to enable: checkout.session.completed, customer.subscription.updated,
#                   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
